# EmailJS - https://www.emailjs.com/
# 1. Sign up and connect your email (Gmail, etc.)
# 2. Create two email templates (Contact + Pricing) - see README for variable names
# 3. Copy your Public Key, Service ID, and Template IDs from the dashboard
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id
VITE_EMAILJS_PRICING_TEMPLATE_ID=your_pricing_template_id
